{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "G1R Optimizer",
  "version": "0.1.0",
  "identifier": "dev.lenni.g1r-optimizer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "G1R Optimizer",
        "width": 1240,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "shortDescription": "Preset installer and config optimizer for Gothic 1 Remake.",
    "resources": {
      "../../Presets": "Presets"
    }
  }
}
