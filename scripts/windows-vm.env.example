# Copy this file to scripts/windows-vm.env and adjust local paths as needed.
# scripts/windows-vm.env is ignored by git.

# VM identity and local storage. Relative paths are resolved from the repo root.
VM_NAME="g1r-win11"
VM_DIR="vm/windows"
DISK_SIZE="80G"

# Runtime resources.
MEMORY_MB="8192"
CPUS="4"
ACCEL="kvm"
CPU_MODEL=""
SECURE_BOOT="1"

# Windows setup media. Leave empty to auto-detect common Windows 11 ISO names in
# $HOME/Downloads, or set an absolute path.
WINDOWS_ISO=""

# Optional VirtIO driver ISO. The VM defaults to SATA/e1000e so installation can
# start without VirtIO drivers. Set this and DISK_BUS=virtio for better IO.
VIRTIO_ISO=""

# sata is easiest for Windows setup. virtio needs the VirtIO ISO during install.
DISK_BUS="sata"
NETWORK_DEVICE="e1000e"

# auto enables TPM when swtpm is installed. Use 0 to disable or 1 to require it.
ENABLE_TPM="auto"

# Share the repository into Windows as \\10.0.2.4\qemu when smbd is installed.
SHARE_REPO="1"
SHARE_DIR=""

# Display backend for qemu-system-x86_64. Common values: gtk, sdl, none.
# zoom-to-fit keeps the 1080p guest display usable on smaller host windows.
DISPLAY_BACKEND="gtk,zoom-to-fit=on"

# Initial UEFI/Windows display mode. Use WIDTHxHEIGHT.
DISPLAY_RESOLUTION="1920x1080"

# QEMU video device. VGA works without extra Windows drivers; virtio-vga or qxl-vga
# can be used after installing matching guest drivers.
VIDEO_DEVICE="VGA"

# Override OVMF paths only if auto-detection does not work on your distro.
OVMF_CODE=""
OVMF_SECURE_CODE=""
OVMF_VARS_TEMPLATE=""
